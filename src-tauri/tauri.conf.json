{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Finder_All",
  "version": "0.1.0",
  "identifier": "com.finderall.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Finder_All - 极速文件搜索",
        "width": 1000,
        "height": 650,
        "minWidth": 700,
        "minHeight": 450,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
